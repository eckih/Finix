# Optional: FRED API Key für USA-Abfrage (WDTGAL, RRPONTSYD)
# Kostenlos: https://fred.stlouisfed.org/docs/api/api_key.html
# Kopiere diese Datei nach .env und trage deinen Key ein.
FRED_API_KEY=YOUR-KEY

# Optional: Alpha Vantage API Key für News (Menüpunkt News)
# Kostenlos: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=YOUR-KEY

# Optional: LM Studio (lokales Modell für AI im News-Menü)
# Ohne Docker: http://localhost:1234
# Mit Docker: http://host.docker.internal:1234 (wie OpenClaw)
# LM_STUDIO_URL=http://host.docker.internal:1234
# LM_STUDIO_MODEL=qwen2.5-coder-1.5b-instruct
# LM_STUDIO_API_KEY=lm-studio

# Optional: Google Gemini API (Modellauswahl: Gemini 2.5 Flash, Gemini 2.5 Pro)
# API-Key: https://aistudio.google.com/app/apikey
# Projektnummer: 256883785618
# Projektname: rprojects/256883785618
# Name: Test1
GEMINI_API_KEY=YOUR-KEY

# Optional: Anthropic API (Modell Sonnet 4.6)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR-KEY

# Optional: Finnhub API (zweiter News-Feed, nur neue Meldungen, Übersetzung in konfigurierter Sprache)
# https://finnhub.io/register
FINNHUB_API_KEY=YOUR-KEY

# News-Übersetzung (DE): Zuerst lokale LibreTranslate (siehe libretranslate/lt-local), dann SimplyTranslate, dann MyMemory.
# Lokale LibreTranslate: Docker → http://host.docker.internal:5000, ohne Docker → http://localhost:5000
LIBRETRANSLATE_URL=http://host.docker.internal:5000
# Optional: MYMEMORY_EMAIL=deine@email.de  (50k Zeichen/Tag), SIMPLYTRANSLATE_API_KEY= (simplytranslate.ai)
